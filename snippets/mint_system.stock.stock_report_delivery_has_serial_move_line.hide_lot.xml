<data priority="50">

    <xpath expr="//t[@name='move_line_lot']" position="replace">
        <t t-if="valued"/>
        <t t-if="not valued">
            <t t-if="has_serial_number" name="move_line_lot">
                <td>
                    <span t-field="move_line.lot_id.name"/>
                </td>
            </t>
        </t>
    </xpath>

</data>