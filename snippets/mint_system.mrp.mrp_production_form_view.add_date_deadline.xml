<data priority="50">
    <field name="user_id" position="before">
        <field name="date_deadline"/>
    </field>
    <data>
        <xpath expr="//field[@name='move_raw_ids']/tree[1]/field[@name='product_id']" position="after">
            <field name="date_deadline" optional="hide"/>
        </xpath>
    </data>
    <data>
        <xpath expr="//field[@name='move_raw_ids']/tree[1]/field[@name='product_id']" position="after">
            <field name="date"/>
        </xpath>
    </data>
</data>
