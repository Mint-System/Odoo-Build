<data inherit_id="report_lot_label" priority="50">
    <xpath expr="//t[@t-name='stock.report_lot_label']" position="replace">

        <t t-name="stock.report_lot_label">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <t t-call="web.html_container">

                        <table style="border: 1px solid white; height: 23mm; width: 38mm; background-color: white;">
                            <tr>
                                <td>
                                    <span t-out="o.product_id.default_code"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span t-if="len(o.product_id.name) &lt;= 20" t-out="o.product_id.name" style="font-size:8pt;"/>

                                    <span t-elif="len(o.product_id.name) &lt;= 40" t-out="o.product_id.name" style="font-size:6pt;"/>

                                    <span t-else="" t-out="o.product_id.name" style="font-size:4pt;"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span t-out="o.name" style="font-size:10pt;"/>
                                </td>
                            </tr>
                          
                            <tr>
                                <td>
                                    <div class="text-center">
                                        <span t-if="o.name" t-esc="o.name" style="margin-bottom: 0px;" t-options="{'widget': 'barcode', 'humanreadable': 0, 'quiet': 0, 'symbology': 'auto','img_style': 'width:50mm;height:7mm;display:block;margin:0;padding-right:5px;'}">
                                        </span>
                                    </div>
                                </td>
                            </tr>
                            
                            
                        </table>
                    </t>

                </t>
            </t>
        </t>

    </xpath>
</data>