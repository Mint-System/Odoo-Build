#!/usr/bin/env python3
"""
Start Jupyter Lab with a preloaded Odoo environment.

The notebook itself contains NO bootstrap code.
Everything is initialized in the kernel startup process.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
from pathlib import Path


STARTUP_TEMPLATE = r'''
import os
import atexit

import odoo
from odoo import api
from odoo.modules.registry import Registry
from odoo.tools import config


db_name = os.environ["DB_NAME"]

config["db_name"] = db_name
config["db_host"] = os.environ.get("PGHOST", "localhost")
config["db_port"] = os.environ.get("PGPORT", "5432")
config["db_user"] = os.environ.get("PGUSER", "odoo")
config["db_password"] = os.environ.get("PGPASSWORD", "odoo")


registry = Registry(db_name)
cr = registry.cursor()

uid = 2

ctx = api.Environment(cr, uid, {})["res.users"].context_get()

env = api.Environment(cr, uid, ctx)

self = env.user


ip = get_ipython()

ip.push({
    "odoo": odoo,
    "env": env,
    "cr": cr,
    "uid": uid,
    "self": self,
    "api": api,
})


@atexit.register
def _cleanup():
    try:
        cr.rollback()
        cr.close()
    except Exception:
        pass


print("=" * 60)
print(f"Odoo ready: {db_name}")
print(f"User: {env.user.name}")
print(f"Models: {len(env.registry.models)}")
print("=" * 60)
'''


def create_notebook(path: Path) -> None:
    """
    Create a clean notebook with zero bootstrap code.
    """

    if path.exists():
        return

    notebook = {
        "cells": [
            {
                "cell_type": "markdown",
                "metadata": {},
                "source": [
                    "# Odoo Notebook\n",
                    "\n",
                    "Available automatically:\n",
                    "\n",
                    "- `env`\n",
                    "- `cr`\n",
                    "- `odoo`\n",
                    "- `self`\n",
                    "- `uid`\n",
                    "- `api`\n",
                ],
            },
            {
                "cell_type": "code",
                "execution_count": None,
                "metadata": {},
                "outputs": [],
                "source": [
                    "env.user.name"
                ],
            },
        ],
        "metadata": {
            "kernelspec": {
                "display_name": "Python 3",
                "language": "python",
                "name": "python3",
            },
            "language_info": {
                "name": "python",
            },
        },
        "nbformat": 4,
        "nbformat_minor": 5,
    }

    path.write_text(json.dumps(notebook, indent=2))


def create_startup_script(ipython_dir: Path) -> None:
    """
    Create IPython startup hook.
    """

    startup_dir = ipython_dir / "profile_default" / "startup"
    startup_dir.mkdir(parents=True, exist_ok=True)

    startup_file = startup_dir / "00-odoo.py"

    startup_file.write_text(STARTUP_TEMPLATE)


def main() -> None:
    parser = argparse.ArgumentParser()

    parser.add_argument(
        "database",
        nargs="?",
        default=os.environ.get("DB_NAME", "odoo"),
    )

    args = parser.parse_args()

    db_name = args.database

    script_dir = Path(__file__).resolve().parent
    project_root = script_dir.parent

    notebook_dir = project_root / "tmp"
    notebook_dir.mkdir(exist_ok=True)

    ipython_dir = notebook_dir / ".ipython"

    env = os.environ.copy()

    env["DB_NAME"] = db_name
    env.setdefault("PGHOST", "localhost")
    env.setdefault("PGPORT", "5432")
    env.setdefault("PGUSER", "odoo")
    env.setdefault("PGPASSWORD", "odoo")

    env["IPYTHONDIR"] = str(ipython_dir)

    create_startup_script(ipython_dir)

    create_notebook(notebook_dir / "main.ipynb")

    print()
    print("=" * 60)
    print("Starting Jupyter Lab with Odoo")
    print("=" * 60)
    print(f"Database : {db_name}")
    print(f"Notebook : {notebook_dir}")
    print()

    cmd = [
        "jupyter-lab",
        f"--ServerApp.root_dir={notebook_dir}",
        "--ServerApp.open_browser=True",
        "--ServerApp.port=8888",
    ]

    subprocess.run(cmd, env=env)


if __name__ == "__main__":
    main()