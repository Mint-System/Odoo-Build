<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="module_category_$CATEGORY" model="ir.module.category">
        <field name="name">$CATEGORY_NAME</field>
        <field name="description">$CATEGORY_HELP</field>
        <field name="sequence">3</field>
    </record>

    <record id="group_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_$CATEGORY" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_$CATEGORY" />
        <field name="implied_ids" eval="[(4, ref('group_user'))]" />
        <field
            name="users"
            eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
        />
    </record>


    <record id="group_privilege_$CATEGORY" model="res.groups.privilege">
        <field name="name">$CATEGORY_NAME</field>
        <field name="description">$CATEGORY_HELP</field>
        <field name="sequence">3</field>
    </record>

    <record id="group_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="group_privilege_$CATEGORY" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="group_privilege_$CATEGORY" />
        <field name="user_ids" eval="[(4, ref('group_user'))]" />
        <field
            name="users"
            eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
        />
    </record>

</odoo>
